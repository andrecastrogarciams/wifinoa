# ============================================
# Wi-Fi Viposa S.A. - Configurações de Ambiente
# ============================================

# Django Core
DJANGO_SECRET_KEY=sua-chave-secreta-aqui
# Default seguro para producao. Em desenvolvimento, habilite explicitamente com True.
DJANGO_DEBUG=False
# Liste apenas os hosts reais do ambiente. Em producao, use o dominio/IP publicado.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Database (Escolha: django.db.backends.mysql ou django.db.backends.sqlite3)
# Em producao, a aplicacao usa MySQL compartilhado com o FreeRADIUS.
DB_ENGINE=django.db.backends.mysql
DB_NAME=radius
DB_USER=radius
DB_PASSWORD=radpass
DB_HOST=localhost
DB_PORT=3306

# RADIUS Settings (opcional, para CoA ou outros scripts)
RADIUS_SECRET=testing123
RADIUS_SERVER_IP=127.0.0.1
